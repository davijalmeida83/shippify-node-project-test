{
  "name": "default",
  "type": "mysql",
  "host": "localhost",
  "port": 3306,
  "username": "shippify_user",
  "password": "shippify_password",
  "database": "shippify_db",
  "synchronize": false,
  "logging": false,
  "entities": ["dist/modules/**/domain/*.js", "dist/shared/db/entities/*.js"],
  "migrations": ["dist/shared/db/migrations/*.js"],
  "subscribers": [
    "dist/shared/db/subscribers/*.js",
    "dist/modules/**/subscribers/*.js"
  ],
  "migrationsTableName": "typeorm_migrations"
}
